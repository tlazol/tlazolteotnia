{
  "name": "tlazol",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "generate:og": "tsx scripts/generate-og-images.tsx",
