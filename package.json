    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-router": "8.1.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@cloudflare/vite-plugin": "^1.42.4",
    "@react-router/dev": "8.1.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "satori": "^0.26.0",
